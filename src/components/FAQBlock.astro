---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-3">
  {
    items.map((item) => (
      <details class="group rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-5 shadow-[0_10px_24px_rgba(96,29,29,0.05)]">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-extrabold text-[#601d1d]">
          <span>{item.question}</span>
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#f6f1e8] text-[#a96f40] transition group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-sm leading-6 text-[#5d4c43]">{item.answer}</p>
      </details>
    ))
  }
</div>
