---
import Button from "./Button.astro";

interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow,
  title,
  intro,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref
} = Astro.props;

const hasActions = Boolean((primaryLabel && primaryHref) || (secondaryLabel && secondaryHref));
---

<section class="site-grid-bg relative overflow-hidden bg-[#f8f7f4]">
  <div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-16 lg:px-8">
    <div class="max-w-3xl">
      {eyebrow ? <p class="mt-5 text-sm font-extrabold text-[#a96f40]">{eyebrow}</p> : null}
      <h1 class="mt-4 max-w-4xl text-[2.35rem] font-extrabold leading-[1.08] text-[#601d1d] sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-[#5d4c43] sm:text-lg">
        {intro}
      </p>
      {
        hasActions ? (
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            {primaryLabel && primaryHref ? <Button href={primaryHref}>{primaryLabel}</Button> : null}
            {secondaryLabel && secondaryHref ? <Button href={secondaryHref} variant="secondary">{secondaryLabel}</Button> : null}
          </div>
        ) : null
      }
    </div>
  </div>
</section>
