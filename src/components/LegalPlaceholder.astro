---
import PageHero from "./PageHero.astro";
import Section from "./Section.astro";

interface Props {
  title: string;
  intro: string;
}

const { title, intro } = Astro.props;
---

<PageHero
  badge="Legal placeholder"
  title={title}
  intro={intro}
  primaryHref="/contact#forms"
  primaryLabel="Contact EDD Hub"
  secondaryHref="/legal"
  secondaryLabel="Legal hub"
  highlights={["Placeholder only", "Owner review needed", "Before public launch"]}
/>

<Section title="Placeholder document" tone="white">
  <div class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-5 text-sm font-bold leading-6 text-[#4a3731]">
    This document will be added before public launch. For questions, contact <a class="text-[#601d1d] underline" href="mailto:info@eddhub.co.uk">info@eddhub.co.uk</a>.
  </div>
</Section>
