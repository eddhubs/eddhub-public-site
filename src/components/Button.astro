---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost" | "dark";
  class?: string;
  target?: string;
  rel?: string;
  type?: "button" | "submit" | "reset";
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  class: className = "",
  target,
  rel,
  type = "button",
  ariaLabel
} = Astro.props;

const variants = {
  primary:
    "border-[#601d1d] bg-[#601d1d] text-[#fffaf3] shadow-[0_12px_28px_rgba(96,29,29,0.18)] hover:-translate-y-0.5 hover:bg-[#4c1616]",
  secondary:
    "border-[#a97c50]/30 bg-[#fffaf3] text-[#601d1d] hover:-translate-y-0.5 hover:border-[#a97c50]/55 hover:bg-white",
  ghost: "border-transparent bg-transparent text-[#601d1d] hover:bg-[#fffaf3]",
  dark: "border-[#171717] bg-[#171717] text-[#fffaf3] hover:-translate-y-0.5 hover:bg-[#301d14]"
};

const classes = [
  "inline-flex min-h-11 items-center justify-center rounded-[10px] border px-5 py-3 text-center text-sm font-extrabold transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbb040] focus-visible:ring-offset-2 focus-visible:ring-offset-[#f8f7f4] sm:w-auto",
  variants[variant],
  className
]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a aria-label={ariaLabel} class={classes} href={href} rel={rel} target={target}>
      <slot />
    </a>
  ) : (
    <button aria-label={ariaLabel} class={classes} type={type}>
      <slot />
    </button>
  )
}
