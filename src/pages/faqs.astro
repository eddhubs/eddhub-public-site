---
import FAQBlock from "../components/FAQBlock.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqs } from "../data/faqs";
import { seo } from "../data/site";
---

<BaseLayout title={seo.faqs.title} description={seo.faqs.description} path={seo.faqs.path}>
  <main>
    <PageHero
      title="EDD Hub FAQs"
      intro="Answers for takeaways, independent drivers and local partners about overflow delivery coordination."
      primaryHref="/contact#general-enquiry"
      primaryLabel="Ask another question"
      secondaryHref="/how-it-works"
      secondaryLabel="How it works"
    />

    <Section title="Common questions" intro="These answers explain how EDD Hub fits around takeaways, independent drivers and local rollout." tone="white">
      <FAQBlock items={faqs} />
    </Section>
  </main>
</BaseLayout>
