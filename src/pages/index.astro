---
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import CTASection from "../components/CTASection.astro";
import IconCard from "../components/IconCard.astro";
import Section from "../components/Section.astro";
import StackedCards from "../components/StackedCards.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { locations } from "../data/locations";
import { seo } from "../data/site";

const stackedCards = [
  {
    title: "Busy night backup",
    text: "Use EDD Hub for the pressure points: the missing driver, the late rush, or the run that needs clearing now."
  },
  {
    title: "Keep your customers",
    text: "Customers stay with your takeaway. EDD Hub does not take orders, own the customer relationship or become your marketplace."
  },
  {
    title: "Clear local runs",
    text: "Single and bundled runs keep delivery support focused on the actual job, not on marketplace browsing."
  },
  {
    title: "Cleaner handovers",
    text: "Job references and accepted driver details help staff check the right person is collecting the right bags."
  },
  {
    title: "Useful progress",
    text: "Takeaways and drivers can follow the job status without adding noisy tracking features that do not help the handover."
  }
];
---

<BaseLayout title={seo.home.title} description={seo.home.description} path={seo.home.path}>
  <main>
    <section class="site-grid-bg relative overflow-hidden bg-[#f8f7f4]">
      <div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 sm:py-18 lg:px-8">
        <div class="max-w-4xl">
          <h1 class="max-w-4xl text-4xl font-extrabold leading-tight text-[#601d1d] sm:text-5xl lg:text-6xl">
            Extra delivery drivers when your takeaway needs them
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-7 text-[#5d4c43] sm:text-lg">
            EDD Hub gives local takeaways a way to request extra delivery support on busy nights, without handing customer orders to another marketplace.
          </p>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <Button href="/contact">Register interest</Button>
            <Button href="/how-it-works" variant="secondary">See how it works</Button>
          </div>
        </div>
      </div>
    </section>

    <Section title="Built for two local audiences" tone="white">
      <div class="grid gap-4 md:grid-cols-2">
        <article class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-6 shadow-[0_12px_30px_rgba(96,29,29,0.06)]">
          <h2 class="text-2xl font-extrabold text-[#601d1d]">For takeaways</h2>
          <p class="mt-3 text-sm leading-6 text-[#5d4c43]">Request delivery backup when the rush is moving faster than your normal driver setup.</p>
          <Button href="/for-takeaways" variant="secondary" class="mt-5">Read more</Button>
        </article>
        <article class="rounded-lg border border-[#2f8f5b]/20 bg-[#e7f4ec] p-6 shadow-[0_12px_30px_rgba(47,143,91,0.08)]">
          <h2 class="text-2xl font-extrabold text-[#236b43]">For drivers</h2>
          <p class="mt-3 text-sm leading-6 text-[#315f45]">Review local delivery runs, see the offered payment and choose whether the run works for you.</p>
          <Button href="/for-drivers" variant="dark" class="mt-5">Read more</Button>
        </article>
      </div>
    </Section>

    <Section
      title="Built for real takeaway pressure"
      intro="Use EDD Hub where delivery pressure actually hurts: when food is ready, customers are waiting and your normal plan needs backup."
      tone="warm"
    >
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <IconCard icon="clock" title="Driver gap on a busy night" text="When a regular driver is off, delayed or unavailable, request extra delivery support without rebuilding the shift." tone="gold" />
        <IconCard icon="bundle" title="Orders backing up" text="Use a single or bundled run to clear pressure before food quality and customer patience suffer." tone="teal" />
        <IconCard icon="route" title="Weekend rush support" text="Bring in EDD Hub for the pressure points, not as a replacement for your normal delivery setup." tone="blue" />
        <IconCard icon="takeaway" title="Keep your customers" text="EDD Hub supports delivery capacity. It does not take customer orders, payments or the customer relationship." tone="green" />
      </div>
    </Section>

    <Section
      title="How EDD Hub works"
      intro="From kitchen pressure to a driver on the way, the flow stays simple."
      tone="white"
    >
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <IconCard icon="message" title="1. Create the run" text="The takeaway adds the delivery area, postcode, ready time, driver payment and slip photo." tone="brand" />
        <IconCard icon="route" title="2. Send it out" text="The run is shown to available local drivers in the operating area." tone="teal" />
        <IconCard icon="clock" title="3. A driver accepts" text="The driver chooses 5 mins or 10 mins so the takeaway knows when to expect collection." tone="gold" />
        <IconCard icon="handover" title="4. Confirm the handover" text="The driver shows the job reference before bags are handed over." tone="green" />
        <IconCard icon="list" title="5. Follow progress" text="Both sides can follow job status, with a clear timeline if something needs review." tone="blue" />
      </div>
    </Section>

    <Section
      title="Where EDD Hub fits"
      intro="The service is not a customer marketplace. It is practical coordination for local overflow delivery moments."
      tone="warm"
    >
      <StackedCards cards={stackedCards} />
    </Section>

    <Section
      title="Built for clear handovers and fewer arguments"
      intro="The job flow is designed to give takeaways and drivers the details they need, without turning the service into a customer marketplace."
      tone="white"
    >
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <IconCard icon="handover" title="Clear collection checks" text="Takeaways see accepted driver details and the job reference before handing over bags." tone="brand" />
        <IconCard icon="takeaway" title="No marketplace confusion" text="Customers stay with the takeaway. EDD Hub does not take food orders or customer payments." tone="gold" />
        <IconCard icon="route" title="Progress without driver maps" text="Takeaways see useful job progress without nearby-driver lists or unnecessary clutter." tone="teal" />
        <IconCard icon="list" title="Records when something goes wrong" text="Job references, timestamps and reports help EDD Hub review issues properly." tone="blue" />
      </div>
    </Section>

    <Section
      title="Starting locally, expanding carefully"
      intro="EDD Hub is building around real local demand first, then opening waiting lists for nearby areas."
      tone="warm"
    >
      <div class="grid gap-4 md:grid-cols-3">
        {locations.map((location) => (
          <a class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-5 shadow-[0_12px_30px_rgba(96,29,29,0.06)] transition hover:-translate-y-1 hover:border-[#a97c50]/35 hover:bg-white" href={location.href}>
            <Badge tone={location.name === "Perth" ? "primary" : "waiting"}>{location.status}</Badge>
            <h3 class="mt-4 text-lg font-extrabold text-[#601d1d]">{location.name}</h3>
            <p class="mt-2 text-sm leading-6 text-[#5d4c43]">{location.intro}</p>
          </a>
        ))}
      </div>
    </Section>

    <Section title="Choose your next step" intro="Takeaways and drivers need different information before registering interest." tone="white">
      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-6">
          <h2 class="text-2xl font-extrabold text-[#601d1d]">For takeaways</h2>
          <p class="mt-3 text-sm leading-6 text-[#5d4c43]">See how overflow support fits around your existing delivery operation.</p>
          <Button href="/for-takeaways" variant="secondary" class="mt-5">Takeaway information</Button>
        </div>
        <div class="rounded-lg border border-[#2f8f5b]/20 bg-[#e7f4ec] p-6">
          <h2 class="text-2xl font-extrabold text-[#236b43]">For drivers</h2>
          <p class="mt-3 text-sm leading-6 text-[#315f45]">Understand the independent driver flow and register interest locally.</p>
          <Button href="/for-drivers" variant="dark" class="mt-5">Driver information</Button>
        </div>
      </div>
    </Section>

    <CTASection
      title="Ready to register interest?"
      text="Tell EDD Hub whether you are a takeaway, independent driver, or partner contact so the right person can follow up."
      primaryLabel="Register interest"
      primaryHref="/contact"
      secondaryLabel="View locations"
      secondaryHref="/locations"
    />
  </main>
</BaseLayout>
