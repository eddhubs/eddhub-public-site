---
import LegalDocumentPage from "../../components/LegalDocumentPage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  coreLegalSlugs,
  legalDocuments,
  type LegalDocument
} from "../../data/legalDocuments";

export function getStaticPaths() {
  return legalDocuments
    .filter((document) => !coreLegalSlugs.includes(document.slug as (typeof coreLegalSlugs)[number]))
    .map((document) => ({
      params: { slug: document.slug },
      props: { document }
    }));
}

interface Props {
  document: LegalDocument;
}

const { document } = Astro.props;
---

<BaseLayout title={`${document.title} | EDD Hub`} description={document.summary} path={`/legal/${document.slug}`}>
  <main>
    <LegalDocumentPage document={document} />
  </main>
</BaseLayout>
