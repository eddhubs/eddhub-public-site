---
import ContactForm from "../components/ContactForm.astro";
import Button from "../components/Button.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { seo, site } from "../data/site";

const basicFields = [
  { name: "name", label: "Name", autocomplete: "name", required: true },
  { name: "email", label: "Email", type: "email", autocomplete: "email", required: true },
  { name: "phone", label: "Phone", type: "tel", autocomplete: "tel" },
  { name: "subject", label: "Subject", autocomplete: "off" },
  { name: "message", label: "Message", textarea: true, autocomplete: "off", required: true }
] as const;

const takeawayFields = [
  { name: "name", label: "Contact name", autocomplete: "name", required: true },
  { name: "businessName", label: "Business or takeaway name", autocomplete: "organization" },
  { name: "email", label: "Email", type: "email", autocomplete: "email", required: true },
  { name: "phone", label: "Phone", type: "tel", autocomplete: "tel" },
  { name: "city", label: "Town/city", autocomplete: "address-level2" },
  { name: "postcode", label: "Postcode or delivery area", autocomplete: "postal-code" },
  { name: "roughUsage", label: "Expected usage or notes", autocomplete: "off" },
  { name: "message", label: "Message", textarea: true, autocomplete: "off", required: true }
] as const;

const driverFields = [
  { name: "name", label: "Full name", autocomplete: "name", required: true },
  { name: "email", label: "Email", type: "email", autocomplete: "email", required: true },
  { name: "phone", label: "Phone", type: "tel", autocomplete: "tel" },
  { name: "city", label: "Town/city", autocomplete: "address-level2" },
  { name: "vehicleType", label: "Vehicle type", autocomplete: "off" },
  { name: "deliveryExperience", label: "Delivery experience", autocomplete: "off" },
  { name: "message", label: "Message", textarea: true, autocomplete: "off", required: true }
] as const;

const partnerFields = [
  { name: "name", label: "Name", autocomplete: "name", required: true },
  { name: "organisationName", label: "Organisation name", autocomplete: "organization" },
  { name: "email", label: "Email", type: "email", autocomplete: "email", required: true },
  { name: "phone", label: "Phone", type: "tel", autocomplete: "tel" },
  { name: "subject", label: "Subject or enquiry reason", autocomplete: "off" },
  { name: "message", label: "Message", textarea: true, autocomplete: "off", required: true }
] as const;

const enquiryCards = [
  {
    id: "takeaway-enquiry",
    title: "Takeaway enquiry",
    label: "Register takeaway interest",
    text: "For takeaway owners or managers who want to use EDD Hub for overflow delivery support.",
    href: "#takeaway-enquiry",
    tone: "brand"
  },
  {
    id: "driver-enquiry",
    title: "Driver enquiry",
    label: "Register driver interest",
    text: "For independent drivers who want to hear about local EDD Hub rollout and driver onboarding.",
    href: "#driver-enquiry",
    tone: "green"
  },
  {
    id: "general-enquiry",
    title: "General enquiry",
    label: "General enquiry",
    text: "For general questions about EDD Hub, local rollout or how the service works.",
    href: "#general-enquiry",
    tone: "gold"
  },
  {
    id: "partnership-enquiry",
    title: "Partnership or media enquiry",
    label: "Partnership or media enquiry",
    text: "For partnerships, local press, insurance, councils, business support or other external enquiries.",
    href: "#partnership-enquiry",
    tone: "blue"
  }
] as const;

const toneClasses = {
  brand: "border-[#a97c50]/18 bg-[#fffaf3]",
  green: "border-[#2f8f5b]/22 bg-[#e7f4ec]",
  gold: "border-[#fbb040]/45 bg-[#fff6df]",
  blue: "border-[#2f6f9f]/20 bg-[#e8f1f6]"
};
---

<BaseLayout title={seo.contact.title} description={seo.contact.description} path={seo.contact.path}>
  <main>
    <PageHero
      title="Contact EDD Hub"
      intro="Choose the enquiry that fits what you need and EDD Hub will show the right form on this page."
    />

    <Section title="Choose the right enquiry" intro="Select the option that best matches what you need. We'll show the right form without sending you to a different page." tone="white">
      <div class="grid gap-4 md:grid-cols-2">
        {enquiryCards.map((card) => (
          <a
            class:list={[
              "enquiry-option rounded-lg border p-5 shadow-[0_12px_30px_rgba(96,29,29,0.06)] transition hover:-translate-y-1 hover:border-[#a97c50]/45 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbb040] focus-visible:ring-offset-2",
              toneClasses[card.tone]
            ]}
            href={card.href}
            data-enquiry-trigger
            data-enquiry-target={card.id}
            aria-controls={card.id}
            aria-expanded="false"
          >
            <h2 class="text-xl font-extrabold text-[#601d1d]">{card.title}</h2>
            <p class="mt-2 text-sm leading-6 text-[#5d4c43]">{card.text}</p>
            <span class="option-action mt-4 inline-flex rounded-[10px] border border-[#601d1d] bg-[#601d1d] px-4 py-2 text-sm font-extrabold text-[#fffaf3] transition">
              {card.label}
            </span>
          </a>
        ))}
      </div>
    </Section>

    <Section id="contact-form-area" title="Selected enquiry" intro="Choose an option above to open the matching form." tone="warm">
      <div data-contact-placeholder class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-5 text-sm font-bold leading-6 text-[#5d4c43]">
        Choose an enquiry option above and the right form will open here.
      </div>
      <div class="grid gap-5">
        <ContactForm id="takeaway-enquiry" enquiryType="takeaway" title="Takeaway enquiry form" intro="For takeaway owners or managers who want to use EDD Hub for overflow delivery support." fields={takeawayFields} hidden />
        <ContactForm id="driver-enquiry" enquiryType="driver" title="Driver enquiry form" intro="For independent drivers who want to hear about local EDD Hub rollout and driver onboarding." fields={driverFields} hidden />
        <ContactForm id="general-enquiry" enquiryType="general" title="General enquiry form" intro="For general questions about EDD Hub, local rollout or how the service works." fields={basicFields} hidden />
        <ContactForm id="partnership-enquiry" enquiryType="partnership" title="Partnership or media enquiry form" intro="For partnerships, local press, insurance, councils, business support or other external enquiries." fields={partnerFields} hidden />
      </div>
    </Section>

    <Section title="Direct contact" intro="You can also contact EDD Hub directly by email." tone="warm">
      <div class="rounded-lg border border-[#a97c50]/18 bg-[#fffaf3] p-5 text-sm font-bold leading-6 text-[#4a3731]">
        <p>Email: <a class="text-[#601d1d] underline" href={`mailto:${site.email}`}>{site.email}</a></p>
        <p class="mt-2">Location: Perth, Scotland</p>
        <Button href={`mailto:${site.email}`} class="mt-5">Email EDD Hub</Button>
      </div>
    </Section>
  </main>

  <style>
    .enquiry-option[aria-expanded="true"] {
      border-color: #601d1d;
      background: #fffaf3;
      box-shadow: 0 18px 42px rgba(96, 29, 29, 0.14);
      transform: translateY(-2px);
    }

    .enquiry-option[aria-expanded="true"] .option-action {
      border-color: #fbb040;
      background: #fbb040;
      color: #601d1d;
    }

    [data-form-status][data-tone="success"] {
      border-color: rgba(47, 143, 91, 0.2);
      background: #e7f4ec;
      color: #236b43;
    }

    [data-form-status][data-tone="error"] {
      border-color: rgba(170, 39, 39, 0.2);
      background: #fff4ee;
      color: #7a1c1c;
    }
  </style>

  <script>
    type EnquiryOptions = { updateHash?: boolean; scroll?: boolean };
    type EnquiryType = "takeaway" | "driver" | "general" | "partnership";

    const enquiryIds = ["takeaway-enquiry", "driver-enquiry", "general-enquiry", "partnership-enquiry"];
    const triggers = Array.from(document.querySelectorAll<HTMLElement>("[data-enquiry-trigger]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-enquiry-panel]"));
    const placeholder = document.querySelector<HTMLElement>("[data-contact-placeholder]");
    const contactForms = Array.from(document.querySelectorAll<HTMLFormElement>("[data-contact-form]"));
    const successMessages: Record<EnquiryType, string> = {
      takeaway: "Thanks. Your takeaway interest has been received. We'll review it and get back to you.",
      driver: "Thanks. Your driver interest has been received. We'll review it and get back to you.",
      general: "Thanks. Your enquiry has been received.",
      partnership: "Thanks. Your partnership/media enquiry has been received."
    };

    function openEnquiry(id: string | null, options: EnquiryOptions = {}) {
      const selectedId = typeof id === "string" && enquiryIds.includes(id) ? id : "";

      triggers.forEach((trigger) => {
        const isSelected = trigger.getAttribute("data-enquiry-target") === selectedId;
        trigger.setAttribute("aria-expanded", String(isSelected));
      });

      panels.forEach((panel) => {
        panel.toggleAttribute("hidden", panel.id !== selectedId);
      });

      if (placeholder) {
        placeholder.toggleAttribute("hidden", Boolean(selectedId));
      }

      if (!selectedId) {
        return;
      }

      if (options.updateHash && window.location.hash !== `#${selectedId}`) {
        history.pushState(null, "", `#${selectedId}`);
      }

      const selectedPanel = document.getElementById(selectedId);

      if (options.scroll && selectedPanel) {
        window.requestAnimationFrame(() => {
          selectedPanel.scrollIntoView({ block: "start", behavior: "smooth" });
          selectedPanel.focus({ preventScroll: true });
        });
      }
    }

    function openFromHash(shouldScroll = false) {
      const id = decodeURIComponent(window.location.hash.replace("#", ""));
      openEnquiry(id, { scroll: shouldScroll });
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        openEnquiry(trigger.getAttribute("data-enquiry-target"), { updateHash: true, scroll: true });
      });
    });

    function statusForForm(form: HTMLFormElement) {
      return form.querySelector<HTMLElement>("[data-form-status]");
    }

    function submitButtonForForm(form: HTMLFormElement) {
      return form.querySelector<HTMLButtonElement>("button[type='submit']");
    }

    function setFormStatus(form: HTMLFormElement, message: string, tone: "default" | "error" | "success" = "default") {
      const status = statusForForm(form);

      if (!status) {
        return;
      }

      status.textContent = message;
      status.dataset.tone = tone;
    }

    function formPayload(form: HTMLFormElement) {
      const data = new FormData(form);
      return Object.fromEntries(data.entries());
    }

    function resetStartedAt(form: HTMLFormElement) {
      const startedAt = form.querySelector<HTMLInputElement>("[data-started-at]");

      if (startedAt) {
        startedAt.value = String(Date.now());
      }
    }

    contactForms.forEach((form) => {
      resetStartedAt(form);

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const submitButton = submitButtonForForm(form);
        const enquiryType = form.dataset.enquiryType as EnquiryType | undefined;

        if (!form.reportValidity()) {
          setFormStatus(form, "Please complete the required fields before sending.", "error");
          return;
        }

        if (!enquiryType || !(enquiryType in successMessages)) {
          setFormStatus(form, "Please choose an enquiry type and try again.", "error");
          return;
        }

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = "Sending...";
        }

        setFormStatus(form, "Sending your enquiry...", "default");

        try {
          const response = await fetch("/api/website-enquiry", {
            body: JSON.stringify(formPayload(form)),
            headers: {
              "Content-Type": "application/json"
            },
            method: "POST"
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok || result?.ok !== true) {
            throw new Error(
              typeof result?.message === "string"
                ? result.message
                : "Your enquiry could not be sent. Please try again."
            );
          }

          form.reset();
          resetStartedAt(form);
          setFormStatus(form, successMessages[enquiryType], "success");
        } catch (error) {
          const errorMessage =
            error instanceof Error
              ? error.message
              : "Your enquiry could not be sent. Please try again.";
          setFormStatus(form, errorMessage, "error");
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = submitButton.dataset.submitLabel ?? "Send enquiry";
          }
        }
      });
    });

    window.addEventListener("hashchange", () => openFromHash(true));
    openFromHash(Boolean(window.location.hash));
  </script>
</BaseLayout>
