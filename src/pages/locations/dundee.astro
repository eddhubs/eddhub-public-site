---
import CTASection from "../../components/CTASection.astro";
import IconCard from "../../components/IconCard.astro";
import PageHero from "../../components/PageHero.astro";
import Section from "../../components/Section.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { seo } from "../../data/site";
---

<BaseLayout title={seo.dundee.title} description={seo.dundee.description} path={seo.dundee.path}>
  <main>
    <PageHero
      title="EDD Hub Dundee waiting list"
      intro="Dundee is treated as a future rollout area while local takeaway and driver interest is gathered."
      primaryHref="/contact#general-enquiry"
      primaryLabel="Join Dundee waiting list"
      secondaryHref="/locations"
      secondaryLabel="All locations"
    />

    <Section title="Register early interest" intro="This page is for demand gathering only until Dundee launch timing is confirmed." tone="white">
      <div class="grid gap-4 md:grid-cols-3">
        <IconCard icon="takeaway" title="Takeaway interest" text="Tell EDD Hub about delivery pressure and your Dundee trading area." tone="brand" />
        <IconCard icon="driver" title="Driver interest" text="Register interest now and complete any required onboarding later." tone="green" />
        <IconCard icon="shield" title="No availability guarantee" text="Waiting-list language avoids promising driver coverage before rollout is approved." tone="gold" />
      </div>
    </Section>

    <CTASection title="Join the Dundee waiting list" text="Register interest now so EDD Hub can understand local takeaway and driver demand." primaryLabel="Contact EDD Hub" primaryHref="/contact#general-enquiry" secondaryLabel="Perth" secondaryHref="/locations/perth" />
  </main>
</BaseLayout>
