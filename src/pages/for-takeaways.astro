---
import CTASection from "../components/CTASection.astro";
import IconCard from "../components/IconCard.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { seo } from "../data/site";
---

<BaseLayout title={seo.takeaways.title} description={seo.takeaways.description} path={seo.takeaways.path}>
  <main>
    <PageHero
      badge="For takeaways"
      title="Delivery backup for busy takeaway nights"
      intro="EDD Hub helps takeaways access overflow delivery support from approved independent drivers when their own delivery capacity is stretched."
      primaryHref="/contact#takeaway-enquiry"
      primaryLabel="Register takeaway interest"
      secondaryHref="/how-it-works"
      secondaryLabel="See the flow"
      highlights={["Existing ordering stays with you", "Single or bundled runs", "No customer marketplace"]}
    />

    <Section title="Use EDD Hub around your existing operation" intro="The platform is designed to support your delivery pressure, not replace how your takeaway receives orders." tone="white">
      <div class="grid gap-4 md:grid-cols-3">
        <IconCard icon="clock" title="Busy-service backup" text="Register interest for support when order volume rises beyond your usual driver capacity." tone="gold" />
        <IconCard icon="bundle" title="Single or bundled runs" text="Coordinate straightforward local runs without turning EDD Hub into a customer app." tone="teal" />
        <IconCard icon="handover" title="Cleaner handover details" text="Operational job references and collection details stay where staff and drivers can follow them." tone="blue" />
      </div>
    </Section>

    <Section title="What EDD Hub is not" intro="Clear boundaries help takeaways understand where EDD Hub fits." tone="warm">
      <div class="grid gap-4 md:grid-cols-2">
        <IconCard icon="check" title="Not a customer marketplace" text="Customers do not browse restaurants, place orders or track deliveries through EDD Hub." tone="brand" />
        <IconCard icon="shield" title="No guaranteed availability" text="EDD Hub helps coordinate support, but does not guarantee drivers or delivery times." tone="green" />
      </div>
    </Section>

    <Section title="Good fit for" intro="EDD Hub is most useful when your takeaway already has orders and needs a clearer way to access extra local delivery capacity." tone="white">
      <div class="grid gap-3 text-sm font-bold leading-6 text-[#4a3731] md:grid-cols-2">
        <p class="rounded-lg bg-[#fffaf3] p-4">Friday and Saturday pressure where your own driver rota is tight.</p>
        <p class="rounded-lg bg-[#fffaf3] p-4">Short-notice sickness, holidays or unexpected delivery demand.</p>
        <p class="rounded-lg bg-[#fffaf3] p-4">Local runs where clear collection and destination handover matters.</p>
        <p class="rounded-lg bg-[#fffaf3] p-4">Takeaways that want overflow support without changing their own ordering setup.</p>
      </div>
    </Section>

    <CTASection
      title="Tell EDD Hub about your takeaway"
      text="Register interest and share your city, business name and the delivery pressure you want help with."
      primaryLabel="Register takeaway interest"
      primaryHref="/contact#takeaway-enquiry"
      secondaryLabel="Pricing"
      secondaryHref="/pricing"
    />
  </main>
</BaseLayout>
