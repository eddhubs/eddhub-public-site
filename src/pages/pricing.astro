---
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pricing, pricingComparison } from "../data/pricing";
import { seo } from "../data/site";

const subscribedFeeList = pricing.subscribedPlatformFees.map((fee) => `${fee.shortLabel}: ${fee.fee}`);
const noSubscriptionFeeList = pricing.noSubscriptionPlatformFees.map((fee) => `${fee.shortLabel}: ${fee.fee}`);

const launchPoints = [
  "No monthly subscription charge during the first month.",
  "Lower subscribed platform fees apply during the first month.",
  "After the first month, continue at £24.99/month or cancel and use no-subscription pricing.",
  "Driver payment remains separate and is paid directly by the takeaway."
];

const scenarios = [
  {
    title: "Occasional backup",
    example: "You only use EDD Hub a few times a month when your regular driver is unavailable.",
    recommendation: "No-subscription pricing may suit you better."
  },
  {
    title: "Weekly overflow",
    example: "You use EDD Hub most weekends or whenever multiple orders build up.",
    recommendation: "Subscription may become cheaper once your monthly usage is high enough."
  },
  {
    title: "Busy regular use",
    example: "You send many single or bundled runs through EDD Hub each month.",
    recommendation: "Subscription is likely to be better value after the free month."
  }
];

const scenarioTones = [
  "border-[#601d1d]/25 bg-[#fff4ee] text-[#601d1d]",
  "border-[#fbb040]/45 bg-[#fff6df] text-[#7a542d]",
  "border-[#2f8f5b]/25 bg-[#e7f4ec] text-[#236b43]"
];

const exampleRunItems = [
  "Driver payment offered: £6.50",
  "Subscribed platform fee: £1.50",
  "No-subscription platform fee: £2.50",
  "Customer pays the takeaway as normal",
  "Takeaway pays the driver directly",
  "EDD Hub platform fee appears on the takeaway invoice"
];

const faqs = [
  {
    question: "Is the first month completely free?",
    answer:
      "No. The monthly subscription charge is waived for the first month, and lower subscribed platform fees apply. Driver payment remains separate and is paid directly by the takeaway."
  },
  {
    question: "What happens after the first month?",
    answer:
      "You can choose whether to continue with a subscription or use no-subscription pricing, depending on how often you use EDD Hub."
  },
  {
    question: "Who pays the driver?",
    answer:
      "The takeaway pays the driver directly using its existing arrangement. EDD Hub does not handle driver payouts at launch."
  },
  {
    question: "Who sets the driver payment?",
    answer:
      "The takeaway sets the payment offered for each run. Drivers see it before deciding whether to accept."
  },
  {
    question: "Which plan is cheaper?",
    answer:
      "If you use EDD Hub regularly, subscription can become cheaper because most subscribed platform fees are £1 lower per run. If you only use it occasionally, no-subscription pricing may suit you better."
  },
  {
    question: "Are customers charged by EDD Hub?",
    answer: "No. Customers order and pay through the takeaway as normal."
  },
  {
    question: "Is VAT charged?",
    answer:
      "EDD Hub is not currently VAT registered. VAT treatment may change if EDD Hub becomes VAT registered later."
  }
];
---

<BaseLayout title={seo.pricing.title} description={seo.pricing.description} path={seo.pricing.path}>
  <main>
    <PageHero
      title="Pricing built for busy takeaways"
      intro="Start with the launch month, use the lower subscribed platform fees, then choose whether subscription or no-subscription pricing fits how often you use EDD Hub."
      primaryHref="/contact#takeaway-enquiry"
      primaryLabel="Register interest"
      secondaryHref="/how-it-works"
      secondaryLabel="How it works"
    />

    <Section title="Your first month is subscription-free" intro="Use the first month to see how often you need EDD Hub before choosing your long-term pricing path." tone="white">
      <div class="rounded-lg border border-[#fbb040]/55 bg-[#fff6df] p-5 shadow-[0_18px_45px_rgba(48,29,20,0.08)] sm:p-7">
        <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
          <div>
            <p class="text-sm font-extrabold text-[#a96f40]">Launch month</p>
            <h2 class="mt-2 text-3xl font-extrabold leading-tight text-[#601d1d]">
              First month: no subscription charge
            </h2>
            <p class="mt-4 leading-7 text-[#5d4c43]">
              You still get the lower subscribed platform fees during the launch month. After that, subscription is £24.99/month unless the takeaway cancels. Driver payment, platform fees and any relevant cancellation compensation remain separate from the waived monthly subscription charge.
            </p>
          </div>

          <ul class="grid gap-3 text-sm font-bold leading-6 text-[#4a3731] sm:grid-cols-2">
            {launchPoints.map((point) => <li class="rounded-lg bg-white px-4 py-3">{point}</li>)}
          </ul>
        </div>
      </div>
    </Section>

    <Section title="Choose the path that matches your usage" intro="After the launch month, pick the option that fits how often you use EDD Hub for overflow delivery support." tone="warm">
      <div class="grid gap-5 lg:grid-cols-2">
        <article class="rounded-lg border border-[#2f8f5b]/28 bg-[#e7f4ec] p-6 shadow-[0_18px_45px_rgba(47,143,91,0.1)]">
          <p class="text-sm font-extrabold text-[#236b43]">Better value for regular use</p>
          <h2 class="mt-2 text-2xl font-extrabold text-[#145149]">Subscribed plan</h2>
          <p class="mt-3 text-sm leading-6 text-[#315f45]">
            Best for takeaways using EDD Hub regularly, especially when delivery support is needed most weeks.
          </p>
          <div class="mt-5 rounded-lg bg-white p-4">
            <p class="text-sm font-extrabold text-[#301d14]">Monthly subscription after the free month</p>
            <p class="mt-2 text-2xl font-extrabold text-[#145149]">{pricing.monthlySubscription.amountLabel}</p>
            <p class="mt-2 text-sm leading-6 text-[#315f45]">Continues after the first month unless the takeaway cancels.</p>
          </div>
          <ul class="mt-5 grid gap-2 text-sm font-bold text-[#4a3731] sm:grid-cols-2">
            {subscribedFeeList.map((item) => <li class="rounded-lg bg-white px-4 py-3">{item}</li>)}
          </ul>
        </article>

        <article class="rounded-lg border border-[#fbb040]/45 bg-[#fff6df] p-6 shadow-[0_18px_45px_rgba(169,111,64,0.12)]">
          <p class="text-sm font-extrabold text-[#a96f40]">Valid for occasional use</p>
          <h2 class="mt-2 text-2xl font-extrabold text-[#601d1d]">No-subscription plan</h2>
          <p class="mt-3 text-sm leading-6 text-[#5d4c43]">
            Best for occasional use if EDD Hub is only needed rarely and a monthly subscription would not suit your usage.
          </p>
          <div class="mt-5 rounded-lg bg-white p-4">
            <p class="text-sm font-extrabold text-[#301d14]">Monthly subscription</p>
            <p class="mt-2 text-lg font-extrabold text-[#601d1d]">£0/month</p>
          </div>
          <ul class="mt-5 grid gap-2 text-sm font-bold text-[#4a3731] sm:grid-cols-2">
            {noSubscriptionFeeList.map((item) => <li class="rounded-lg bg-white px-4 py-3">{item}</li>)}
          </ul>
        </article>
      </div>
    </Section>

    <Section title="Platform fee comparison" intro="The driver payment is not included in this table. The takeaway sets and pays the driver payment separately." tone="white">
      <div class="overflow-x-auto rounded-lg border border-[#eadfce] bg-white shadow-[0_18px_45px_rgba(48,29,20,0.06)]">
        <table class="w-full min-w-[720px] border-collapse text-left text-sm">
          <thead class="bg-[#601d1d] text-[#fffaf3]">
            <tr>
              <th class="px-4 py-4 font-extrabold">Request type</th>
              <th class="px-4 py-4 font-extrabold">Subscribed platform fee</th>
              <th class="px-4 py-4 font-extrabold">No-subscription platform fee</th>
              <th class="px-4 py-4 font-extrabold">Difference</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#eadfce]">
            {
              pricingComparison.map((row) => (
                <tr class="text-[#4a3731]">
                  <td class="px-4 py-4 font-extrabold text-[#601d1d]">{row.requestType}</td>
                  <td class="px-4 py-4 font-bold">{row.subscribedFee}</td>
                  <td class="px-4 py-4 font-bold">{row.noSubscriptionFee}</td>
                  <td class="px-4 py-4 font-bold">{row.difference}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </Section>

    <Section title="When does subscription make sense?" intro="For single deliveries and bundle runs, the subscribed plan saves £1 per run compared with no-subscription pricing." tone="warm">
      <div class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
        <article class="rounded-lg bg-[#fffaf3] p-6">
          <h2 class="text-xl font-extrabold text-[#601d1d]">Around 25 qualifying runs</h2>
          <p class="mt-3 leading-7 text-[#5d4c43]">
            At £24.99/month, subscription is roughly break-even at about 25 qualifying runs per month. A qualifying run is a single delivery or bundle run.
          </p>
        </article>
        <article class="rounded-lg bg-[#fffaf3] p-6">
          <h2 class="text-xl font-extrabold text-[#601d1d]">Example monthly usage</h2>
          <ul class="mt-3 grid gap-3 text-sm font-bold leading-6 text-[#4a3731]">
            <li class="rounded-lg bg-white px-4 py-3">10 qualifying runs/month: no-subscription is usually cheaper.</li>
            <li class="rounded-lg bg-white px-4 py-3">25 qualifying runs/month: subscription is roughly break-even.</li>
            <li class="rounded-lg bg-white px-4 py-3">50 qualifying runs/month: subscription can save around £25/month compared with no-subscription pricing.</li>
          </ul>
        </article>
      </div>
      <p class="mt-5 rounded-lg bg-[#fffaf3] px-5 py-4 text-sm font-bold leading-6 text-[#5d4c43]">
        Each current request type saves £1 per completed run with subscription compared with no-subscription pricing.
      </p>
    </Section>

    <Section title="Which path fits your takeaway?" intro="These examples are a guide, not a guaranteed saving for every takeaway." tone="white">
      <div class="grid gap-4 md:grid-cols-3">
        {
          scenarios.map((scenario, index) => (
            <article class:list={["rounded-lg border p-5 shadow-[0_12px_30px_rgba(48,29,20,0.06)]", scenarioTones[index]]}>
              <h2 class="text-lg font-extrabold">{scenario.title}</h2>
              <p class="mt-3 text-sm leading-6 text-[#5d4c43]">{scenario.example}</p>
              <p class="mt-4 rounded-lg bg-white px-4 py-3 text-sm font-extrabold leading-6 text-[#301d14]">
                {scenario.recommendation}
              </p>
            </article>
          ))
        }
      </div>
    </Section>

    <Section title="Example run" intro="A takeaway creates a single delivery run." tone="warm">
      <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div class="rounded-lg bg-[#601d1d] p-6 text-[#fffaf3] shadow-[0_18px_45px_rgba(96,29,29,0.18)]">
          <p class="text-sm font-extrabold text-[#f4d9b2]">Single delivery</p>
          <p class="mt-4 text-5xl font-extrabold">£1.50</p>
          <p class="mt-2 text-sm font-extrabold text-[#fbb040]">Subscribed platform fee</p>
        </div>

        <div class="rounded-lg border border-[#eadfce] bg-[#fffaf3] p-6">
          <ul class="grid gap-3 text-sm font-bold leading-6 text-[#4a3731] sm:grid-cols-2">
            {exampleRunItems.map((item) => <li class="rounded-lg bg-white px-4 py-3">{item}</li>)}
          </ul>
          <p class="mt-5 text-sm leading-6 text-[#5d4c43]">
            The takeaway chooses the driver payment offered for each run.
          </p>
        </div>
      </div>
    </Section>

    <Section title="Simple weekly billing" intro="EDD Hub records platform fees and invoices takeaways weekly." tone="warm">
      <div class="grid gap-4 md:grid-cols-3">
        <article class="relative rounded-lg border border-[#eadfce] bg-[#fffaf3] p-5 shadow-[0_12px_30px_rgba(48,29,20,0.06)]">
          <span class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#601d1d] text-sm font-extrabold text-[#fffaf3]">1</span>
          <h2 class="text-lg font-extrabold text-[#601d1d]">Weekly period</h2>
          <p class="mt-2 text-sm leading-6 text-[#5d4c43]">Monday 06:00 to the following Monday 05:59:59.</p>
        </article>
        <article class="relative rounded-lg border border-[#eadfce] bg-[#fffaf3] p-5 shadow-[0_12px_30px_rgba(48,29,20,0.06)]">
          <span class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#fbb040] text-sm font-extrabold text-[#601d1d]">2</span>
          <h2 class="text-lg font-extrabold text-[#601d1d]">Manual launch payment</h2>
          <p class="mt-2 text-sm leading-6 text-[#5d4c43]">During launch, payment is handled manually by bank transfer.</p>
        </article>
        <article class="relative rounded-lg border border-[#eadfce] bg-[#fffaf3] p-5 shadow-[0_12px_30px_rgba(48,29,20,0.06)]">
          <span class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#2f8f5b] text-sm font-extrabold text-white">3</span>
          <h2 class="text-lg font-extrabold text-[#601d1d]">Bank details</h2>
          <p class="mt-2 text-sm leading-6 text-[#5d4c43]">Bank details appear on invoices only.</p>
        </article>
      </div>
    </Section>

    <Section title="Pricing FAQs" intro="Short answers for takeaway owners comparing the launch and long-term options." tone="warm">
      <div class="grid gap-4 md:grid-cols-2">
        {
          faqs.map((faq) => (
            <article class="rounded-lg bg-[#fffaf3] p-5">
              <h2 class="text-base font-extrabold text-[#601d1d]">{faq.question}</h2>
              <p class="mt-2 text-sm leading-6 text-[#5d4c43]">{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </Section>

    <CTASection
      title="Start with the free subscription month"
      text="Register interest and we'll explain the launch month, pricing options and onboarding before your account goes live."
      primaryLabel="Register interest"
      primaryHref="/contact#takeaway-enquiry"
      secondaryLabel="Contact EDD Hub"
      secondaryHref="/contact#general-enquiry"
    />
  </main>
</BaseLayout>
